<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="false" android:drawable="@drawable/ic_notify_message" />
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <solid android:color="@color/color_main" />
                </shape>
            </item>
            <item android:drawable="@drawable/ic_notify_message_focus" />
        </layer-list>
    </item>
</selector>