<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/color_bnt_focused" />
            <stroke android:width="2.0px" android:color="@color/color_bnt_focused" />
            <corners android:radius="18.0px" />
        </shape>
    </item>
    <item android:state_focused="false" android:state_hovered="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/color_bnt_focused" />
            <stroke android:width="2.0px" android:color="@color/color_bnt_focused" />
            <corners android:radius="18.0px" />
        </shape>
    </item>
    <item android:drawable="@color/color_00ffffff" />
</selector>