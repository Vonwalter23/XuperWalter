<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <nine-patch android:src="@drawable/focus_navigation" />
            </item>
            <item>
                <shape>
                    <corners android:radius="23.0dip" />
                    <solid android:color="@color/color_bg_home_search" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_focused="false" android:state_hovered="true">
        <layer-list>
            <item android:drawable="@drawable/focus_navigation" />
            <item>
                <shape>
                    <corners android:radius="23.0dip" />
                    <solid android:color="@color/color_bg_home_search" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <shape>
            <corners android:radius="23.0dip" />
            <solid android:color="@color/color_bg_home_search" />
        </shape>
    </item>
</selector>