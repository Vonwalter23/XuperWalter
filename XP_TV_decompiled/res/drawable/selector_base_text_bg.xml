<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <solid android:color="@color/color_bnt_focused" />
            <stroke android:width="1.0dip" android:color="@color/color_bnt_focused" />
            <corners android:radius="18.0px" />
        </shape>
    </item>
    <item android:state_focused="false" android:state_hovered="true">
        <shape>
            <solid android:color="@color/color_bnt_focused" />
            <stroke android:width="1.0dip" android:color="@color/color_bnt_focused" />
            <corners android:radius="18.0px" />
        </shape>
    </item>
    <item>
        <shape>
            <stroke android:width="1.0dip" android:color="@color/color_00ffffff" />
        </shape>
    </item>
</selector>